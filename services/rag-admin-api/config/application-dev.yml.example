# Local development overrides (copy to application-dev.yml; gitignored).
#   cp application-dev.yml.example application-dev.yml

rag-admin:
  seed-admin:
    username: admin
    password: admin123
    display-name: 系统管理员
  default-lightrag:
    name: Local LightRAG
    base-url: http://127.0.0.1:9621
    api-key:
    username: admin
    password: admin123

# PostgreSQL (shared with LightRAG instance)
POSTGRES_HOST: localhost
POSTGRES_PORT: 5431
POSTGRES_USER: postgres
POSTGRES_PASSWORD: your-password-here
POSTGRES_DATABASE: rag
